<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dbmap_background"
    android:padding="24dp">

    <TextView
        android:id="@+id/textTituloMedicion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/titulo_medicion"
        android:textColor="@color/dbmap_text_primary"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/textSubtituloMedicion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/subtitulo_medicion"
        android:textColor="@color/dbmap_text_secondary"
        android:textSize="16sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/textTituloMedicion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardResultado"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="@color/dbmap_card"
        app:cardCornerRadius="20dp"
        app:cardElevation="3dp"
        app:contentPadding="24dp"
        app:layout_constraintTop_toBottomOf="@id/textSubtituloMedicion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/textResultadoRuido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/resultado_medicion_inicial"
            android:textAlignment="center"
            android:textColor="@color/dbmap_text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

    </com.google.android.material.card.MaterialCardView>

    <Button
        android:id="@+id/botonMedir"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/boton_medir_ruido"
        android:textAllCaps="false"
        android:textSize="17sp"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toBottomOf="@id/cardResultado"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/textAvisoPrivacidad"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@color/dbmap_warning_background"
        android:padding="16dp"
        android:text="@string/aviso_privacidad_medicion"
        android:textColor="@color/dbmap_text_secondary"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/botonMedir"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
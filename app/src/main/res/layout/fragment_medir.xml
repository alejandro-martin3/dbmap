<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:id="@+id/textTituloMedicion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/titulo_medicion"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/textResultadoRuido"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/resultado_medicion_inicial"
        android:textSize="18sp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/textTituloMedicion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/textAvisoPrivacidad"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/aviso_privacidad_medicion"
        android:textSize="14sp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/textResultadoRuido"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/botonMedir"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/boton_medir_ruido"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/textAvisoPrivacidad"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>